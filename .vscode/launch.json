{
  "version": "0.2.0",
  "configurations": [
    // ─────────────────────────────────────────────────────────────────────────
    // SERVER-SIDE: Attach to Next.js Node.js process.
    // Start the dev server with: NODE_OPTIONS='--inspect' npm run dev
    // Then launch this config.
    // ─────────────────────────────────────────────────────────────────────────
    {
      "name": "Next.js: server-side (attach)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**"
      ],
      "restart": true,
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    },

    // ─────────────────────────────────────────────────────────────────────────
    // CLIENT-SIDE: Launch Chrome and attach to the running dev server.
    // Requires the app to already be running on localhost:3000.
    // ─────────────────────────────────────────────────────────────────────────
    {
      "name": "Next.js: client-side (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${workspaceFolder}/*",
        "webpack:///*": "${workspaceFolder}/*"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // API ROUTE: Debug a specific API route in isolation.
    // Set breakpoints in src/app/api/gen-ai-chat/route.ts etc.
    // ─────────────────────────────────────────────────────────────────────────
    {
      "name": "Next.js: debug API route (attach)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/next/**"
      ],
      "restart": true,
      "sourceMaps": true
    }
  ],

  // ─────────────────────────────────────────────────────────────────────────
  // COMPOUNDS: Launch server + client debuggers simultaneously.
  // Usage: start `NODE_OPTIONS='--inspect' npm run dev`, then run this.
  // ─────────────────────────────────────────────────────────────────────────
  "compounds": [
    {
      "name": "Next.js: full-stack (server + client)",
      "configurations": [
        "Next.js: server-side (attach)",
        "Next.js: client-side (Chrome)"
      ],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "Next.js",
        "order": 1
      }
    }
  ]
}
