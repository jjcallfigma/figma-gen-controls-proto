    COMPOSE["composePrompt()\n(prompt-composer.ts)"]

    COMPOSE --> MOD["selectModules()\n— keyword-match user message\n→ include only relevant\nprompt modules"]
    COMPOSE --> HIST["prepareHistory()\n— last 3 turns verbatim\n  (generate/actions stripped)\n— older turns summarized\n— 12K char budget"]
    COMPOSE --> GUARD["Token guard\n— estimate chars/4\n— drop oldest if >100K"]

