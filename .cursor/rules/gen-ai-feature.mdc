    GEN --> GENRUN["executeGenerator(fn, params)\n— reset seeded PRNG\n— pass flattenColorStops()\n  control values + lib"]
    GENRUN --> REWRITE2["rewriteActionsForReapply()"]
    REWRITE2 --> EXEC

    EXEC["executeActions()\n(action-adapter.ts)\n— maps each ActionDescriptor\n  to store dispatch\n— returns tempIdMap"]

    EXEC --> POST["Post-processing:\n— shrinkFrameToChildren\n— center in viewport\n— rewrite control action\n  nodeIds via tempIdMap"]

    POST --> PERSIST["Persist on root object:\n— genAiSpec = JSON(mergedUi)\n— genAiValues = JSON(controlValues)\n— select root object"]

    PERSIST --> CONTROLS

    LOCAL --> CONTROLS

    CONTROLS["CustomControlsSection\n→ CustomControlsPopover\n— reads genAiSpec from object\n— renders FigUI3 controls"]

    CONTROLS --> CHANGE{Control value\nchanges}

